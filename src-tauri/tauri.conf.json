{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ash's MEP Playground",
  "version": "2.0.0",
  "identifier": "com.ash.pandid",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ash's MEP Playground",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Ash",
    "copyright": "Copyright © 2026 Ash. All rights reserved.",
    "category": "Productivity",
    "shortDescription": "Local P&ID and electrical design, drafting and analysis tool.",
    "longDescription": "Ash's MEP Playground is a desktop application for mechanical, electrical and plumbing design. Draw P&IDs and electrical single-line diagrams on an infinite canvas, edit per-component parameters in a schema-driven inspector, generate BOMs, schedules of loads and cable schedules with volt-drop analysis, solve single-path hydraulics from pump and system curves, and export A3-landscape PDF drawings with an ISO title block.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pid"],
        "name": "PandIDProject",
        "description": "Ash's MEP Playground project",
        "role": "Editor",
        "mimeType": "application/x-pandid"
      }
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
