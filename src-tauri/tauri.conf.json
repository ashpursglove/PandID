{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ash's P&ID Playground",
  "version": "0.1.0",
  "identifier": "com.pandid.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ash's P&ID Playground",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["pid"],
        "name": "PandIDProject",
        "description": "Ash's P&ID Playground project",
        "role": "Editor",
        "mimeType": "application/x-pandid"
      }
    ]
  }
}
